# Copie este arquivo na VPS para .env e preencha os valores reais.
# Nao comite nem envie o .env real. Use segredos novos, longos e unicos.

# Flask / aplicacao
SECRET_KEY=troque-por-uma-chave-aleatoria-com-64-caracteres-ou-mais
PLATFORM_BASE_URL=https://app.seudominio.com.br
SUPER_ADMIN_EMAILS=admin@seudominio.com

# Banco principal da plataforma
POSTGRES_APP_DB=whatsapp_atendimento
POSTGRES_APP_USER=postgres
POSTGRES_APP_PASSWORD=troque-por-uma-senha-forte-do-postgres-app
DATABASE_URL=postgresql://postgres:troque-por-uma-senha-forte-do-postgres-app@postgres_app:5432/whatsapp_atendimento

# Banco da Evolution API
POSTGRES_EVOLUTION_DB=evolution_db
POSTGRES_EVOLUTION_USER=postgres
POSTGRES_EVOLUTION_PASSWORD=troque-por-uma-senha-forte-do-postgres-evolution

# Evolution API
EVOLUTION_API_KEY=troque-por-uma-chave-forte-da-evolution
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_INTERNAL_WEBHOOK_URL=http://app:5000/webhooks/evolution
EVOLUTION_SERVER_TYPE=http
EVOLUTION_SERVER_PORT=8080

# OpenAI
OPENAI_API_KEY=cole-a-chave-openai-rotacionada-aqui
OPENAI_ASSISTANT_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# PagBank / PagSeguro
# Para validacao inicial, mantenha sandbox.
# Para producao real, troque PAGBANK_ENVIRONMENT=production e ajuste token/base URL.
PAGBANK_API_TOKEN=token-pagbank-novo-aqui
PAGBANK_ENVIRONMENT=sandbox
PAGBANK_API_BASE_URL=https://sandbox.api.pagseguro.com
PAGBANK_SOFT_DESCRIPTOR=APPSUL
PAGSEGURO_WEBHOOK_SECRET=troque-por-um-segredo-longo-para-webhook

# Worker de billing
BILLING_WORKER_ENABLED=true
BILLING_WORKER_INTERVAL_SECONDS=5

# Cupom comercial de teste
# Exemplo: cliente usa TESTE3DIAS, paga R$ 5,00 e a assinatura fica ativa por 3 dias.
COMMERCIAL_TEST_COUPON_CODE=TESTE3DIAS
COMMERCIAL_TEST_COUPON_PRICE_CENTS=500
COMMERCIAL_TEST_COUPON_DAYS=3

# SMTP para envio de credenciais/onboarding
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=usuario@seudominio.com
SMTP_PASSWORD=senha-de-app-ou-senha-smtp-nova
SMTP_FROM=Appsul <usuario@seudominio.com>

# Atendimento
CENTRAL_NEW_CYCLE_GAP_HOURS=24
